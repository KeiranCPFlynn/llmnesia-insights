POSTHOG_PROJECT_ID=
POSTHOG_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=                # OPTIONAL — override the Claude model (default claude-sonnet-4-6)

# --- DeepSeek (alternative LLM, selectable per run/chat in the UI) ---
DEEPSEEK_API_KEY=               # required only when DeepSeek is selected
DEEPSEEK_MODEL=                 # OPTIONAL — override the DeepSeek model (default deepseek-v4-pro)
LLM_PROVIDER=                   # OPTIONAL — default provider when none chosen: claude (default) | deepseek | openai

# --- OpenAI / GPT-5.5 (the PM revenue strategist on the /strategy page) ---
OPENAI_API_KEY=                 # required for the strategist (and if 'openai' is picked anywhere)
STRATEGY_MODEL=                 # OPTIONAL — override the strategist model (default gpt-5.5)
STRATEGY_PROVIDER=              # OPTIONAL — default provider for the strategist: openai (default) | claude | deepseek
STRATEGY_REASONING_EFFORT=      # OPTIONAL — GPT-5.x reasoning spend (cost lever): minimal | low | medium (default) | high

GOOGLE_APPLICATION_CREDENTIALS= # LOCAL only — absolute path, OUTSIDE this repo, e.g. /Users/you/.config/llmnesia/ga4-key.json
GOOGLE_CREDENTIALS_JSON=        # VERCEL — paste the ENTIRE contents of that key JSON file (Vercel has no filesystem path). Takes precedence over the path above when set.
GA4_PROPERTY_ID_WEBSITE=        # numeric GA4 property ID for llmnesia.com (read via the service account)
GA4_PROPERTY_ID_EXTENSION=      # OPTIONAL — numeric GA4 property ID for the Chrome Web Store listing; leave blank to skip

# The extension property is a Chrome-Web-Store-auto-managed GA4 account that Google
# administers — a service account can NEVER be added to it. It is read via OAuth as
# the developer's own Google account instead. One-time setup:
#   1. In the same GCP project, create an OAuth client ID (type: Desktop app) and
#      publish the OAuth consent screen to "In production" (sensitive scope
#      analytics.readonly; a single internal user just bypasses the unverified warning).
#   2. Put the client id/secret below, then run: npx tsx scripts/ga4-oauth-consent.ts
#   3. Paste the printed refresh token into GA4_OAUTH_REFRESH_TOKEN.
# Leave these blank to skip the extension property entirely.
GA4_OAUTH_CLIENT_ID=
GA4_OAUTH_CLIENT_SECRET=
GA4_OAUTH_REFRESH_TOKEN=

# --- Traffic Growth Planner (Google Search Console) ---
# The Growth Planner reads GSC data via OAuth (one refresh token covers every
# GSC property the signing-in Google account owns). Same GCP project + consent
# screen pattern as the GA4 OAuth above. Run scripts/gsc-oauth-consent.ts after
# filling the client id/secret to mint the refresh token.
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
GSC_OAUTH_REFRESH_TOKEN=
GROWTH_PROVIDER=                # OPTIONAL — default provider for /growth plans + briefs: claude (default) | openai | deepseek

# --- Traffic Growth Planner (Bing Webmaster Tools) ---
# Optional — adds Bing search data alongside GSC in the Growth Planner.
# Get your API key from Bing Webmaster Tools → Settings → API Access → API Key.
# Leave blank to skip Bing sync entirely.
BING_WEBMASTER_API_KEY=

# --- Dashboard ---
DASHBOARD_PASSWORD=             # password to view the dashboard once deployed (leave blank to disable the gate)
RUN_SECRET=                     # shared secret the Vercel Cron uses to authorise the weekly /api/run
